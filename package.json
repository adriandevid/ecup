{
  "name": "futchamp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "node -e \"require('fs').readFileSync('sql/schema.sql','utf8').split(';').forEach(s=>s.trim()&&require('child_process').execSync('psql '+process.env.DATABASE_URL+' -c \"'+s.trim().replace(/\"/g,'\\\\\"')+'\"',{stdio:'inherit'}))\""
